<Window x:Class="Gestion_CyberCafe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberCafe" Height="350" Width="600">

    <Grid>

        <!-- MENU -->
        <StackPanel Orientation="Horizontal" Margin="10">
            <Button Content="Clients" Click="BtnClient_Click"/>
            <Button Content="Postes" Click="BtnPoste_Click"/>
            <Button Content="Seance" Click="BtnSeance_Click"/>
            <Button Content="Caisse" Click="BtnCaisse_Click"/>
        </StackPanel>

        <!-- CONTENT -->
        <ContentControl x:Name="MainContent" Margin="10,50,10,10"/>

    </Grid>
  
</Window>