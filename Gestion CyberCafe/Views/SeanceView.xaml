<UserControl x:Class="Gestion_CyberCafe.Views.SeanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Gestion_CyberCafe.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
    <StackPanel Margin="20">
        <TextBlock Text="Seance ID"/>
        <TextBox x:Name="txtSeanceId" Margin="0,5"/>
        <TextBlock Text="Client ID"/>
        <TextBox x:Name="txtClientId"/>

        <TextBlock Text="Poste ID" Margin="0,5"/>
        <TextBox x:Name="txtPosteId"/>

        <Button Content="Start Session"
                Margin="0,10"
                Click="BtnStart_Click"/>

        <Button Content="Stop Session"
                Margin="0,5"
                Click="BtnStop_Click"/>

    </StackPanel>
    </Grid>
</UserControl>
